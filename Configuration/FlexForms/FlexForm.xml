<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<T3DataStructure>
    <sheets>
        <sDEF>
            <ROOT>
                <type>array</type>
                <el>
                    <!-- 1. Number of records to display -->
                    <settings.limit>
                        <label>Number of records to display (Empty for all)</label>
                        <config>
                            <type>input</type>
                            <eval>int</eval>
                            <size>5</size>
                            <default>2</default>
                        </config>
                    </settings.limit>

                    <!-- 2. Option to select sorting (ASC/DESC) -->
                    <settings.sortOrder>
                        <label>Select Sorting Order</label>
                        <config>
                            <type>select</type>
                            <renderType>selectSingle</renderType>
                            <items>
                                <numIndex index="0">
                                    <label>Descending (Newest First)</label>
                                    <value>DESC</value>
                                </numIndex>
                                <numIndex index="1">
                                    <label>Ascending (Oldest First)</label>
                                    <value>ASC</value>
                                </numIndex>
                            </items>
                            <default>DESC</default>
                        </config>
                    </settings.sortOrder>

                    <!-- 3. Select specific storage PID -->
                    <settings.overrideStoragePid>
                        <label>Optional: Select specific storage page (PID)</label>
                        <config>
                            <type>group</type>
                            <allowed>pages</allowed>
                            <size>1</size>
                            <maxitems>1</maxitems>
                            <minitems>0</minitems>
                            <default>0</default>
                        </config>
                    </settings.overrideStoragePid>
                </el>
            </ROOT>
        </sDEF>
    </sheets>
</T3DataStructure>